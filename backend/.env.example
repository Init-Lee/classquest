# 文件说明：后端环境变量示例。
# 职责：列出本地和轻量服务器联调课时 3 Qwen 自检、SQLite 运行时路径所需的非敏感配置项。
# 更新触发：新增后端环境变量、修改默认模型、切换 Qwen endpoint、调整自检限制或数据库路径时，需要同步更新本文件。

LESSON3_AI_REVIEW_PROVIDER=qwen
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen3.5-flash
QWEN_VISION_MODEL=qwen3.5-flash
QWEN_ENABLE_IMAGE_INPUT=false
QWEN_MAX_TOKENS=600
LESSON3_AI_REVIEW_TIMEOUT_SECONDS=45
LESSON3_AI_REVIEW_MAX_IMAGE_BYTES=700000

# 课时 4 互审文字审核（提交审查前）；留空则自动：有 DASHSCOPE_API_KEY 时用 qwen，否则 mock（仅规则预审）
# 显式 qwen 但未配置 key 时返回 503「AI 审核暂不可用」
# LESSON4_REVIEW_MODERATION_PROVIDER=qwen
# mock 联调强制不通过：LESSON4_REVIEW_MODERATION_MOCK_OUTCOME=fail
LESSON4_REVIEW_MODERATION_TIMEOUT_SECONDS=25
LESSON4_REVIEW_MODERATION_MAX_TOKENS=400

# OSS 静态前端跨域白名单（逗号分隔，需包含协议；留空则不启用 CORS）
# 示例：https://tool.xnwyedu.com
CORS_ALLOWED_ORIGINS=https://tool.xnwyedu.com

# SQLite 数据库路径；留空时默认使用 /var/lib/classquest/db/classquest.sqlite
# 本地联调示例（相对 backend/ 目录）：runtime/db/classquest.sqlite
CLASSQUEST_DATABASE_PATH=
