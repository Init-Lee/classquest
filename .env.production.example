# 文件说明：OSS 静态前端生产构建环境变量示例。
# 职责：方案 B 部署时让浏览器通过 HTTPS 直连轻量服务器 API，并启用模块 4 生产 HTTP adapter。
# 更新触发：OSS 域名、后端 HTTPS 域名、AI review 模式、教师控制台或课时 5 HTTP 接入变化时，需要同步更新本文件。

VITE_MODULE4_LESSON3_AI_REVIEW_MODE=http
# 课时 4 同伴互审与文字 AI 审核（需后端 DASHSCOPE_API_KEY + moderate-text）
# 学生端生产构建：保持 http。教师讲解模式会在运行时强制 fixture（见 utils/module4-teacher-mode-flag.ts），
# 不依赖此处改 env，也不会写入学生 IndexedDB。
VITE_MODULE4_LESSON4_PEER_REVIEW_MODE=http
VITE_MODULE4_LESSON4_REVIEW_MODERATION_MODE=http
VITE_TEACHER_CONSOLE_MODE=http
VITE_MODULE4_LESSON5_MODE=http
VITE_API_BASE_URL=https://api.xnwyedu.com
